# ============================================================
#  TIJUANA ACCESIBLE — variables de entorno
#  Copia este archivo a ".env" y rellena los valores.
#  TODO lo que está aquí es lo que TÚ debes integrar.
# ============================================================

# --- Google Maps Platform ---
# Consola: https://console.cloud.google.com/google/maps-apis
# Habilita: Maps JavaScript API, Routes API, Elevation API,
#           Places API (New), Roads API, Weather API
# Crea una API key y restríngela por dominio (tu .web.app)
VITE_GOOGLE_MAPS_API_KEY=AIza...

# --- Gemini (Google AI Studio) ---
# Consola: https://aistudio.google.com/apikey
# Para el HACKATHON puedes llamar Gemini desde el cliente con esta key.
# En producción se mueve a Cloud Function (ver functions/index.js).
VITE_GEMINI_API_KEY=AIza...

# --- Firebase (config del proyecto web) ---
# Consola: https://console.firebase.google.com
# Project settings -> General -> Your apps -> SDK setup and config
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=tijuana-accesible.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tijuana-accesible
VITE_FIREBASE_STORAGE_BUCKET=tijuana-accesible.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abc123

# --- Reporte al 072 (Cloud Function) ---
# Correo institucional al que llega el reporte anónimo.
# Se usa en functions/index.js, no aquí, pero lo dejamos documentado.
# REPORT_EMAIL_TO=072@tijuana.gob.mx
